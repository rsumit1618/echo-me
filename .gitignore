# Firebase and Google service files that can contain project API keys or
# service account material. Keep local copies, commit only sanitized examples.
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart
firebase_service_account*.json
*service-account*.json
*service_account*.json

# Android/iOS signing credentials and local provisioning files
android/key.properties
**/key.properties
**/*.keystore
**/*.jks
**/*.p12
**/*.pem
**/*.key
**/*.mobileprovision
**/*.cer

