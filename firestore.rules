rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if isSelf(uid);
      allow delete: if false;

      match /contacts/{contactId} {
        allow read, write: if isSelf(uid);
      }

      match /calls/{callId} {
        allow read, write: if isSelf(uid);
      }
    }

    match /phoneIndex/{phoneNumber} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant(chatId);
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if isChatParticipant(chatId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read, update: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid;
        allow delete: if false;

        match /chunks/{chunkId} {
          allow read, create: if isChatParticipant(chatId);
          allow update, delete: if false;
        }
      }
    }

    match /notificationRequests/{requestId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
